y_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE IF NOT EXISTS infrazioni_velocita (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    id_biglietto    INTEGER NOT NULL,
    targa           TEXT    NOT NULL,

    cap             TEXT    NOT NULL,
    id_casello      INTEGER NOT NULL,
    direzione       TEXT    NOT NULL,

    id_tratta       INTEGER DEFAULT 0,
    km_rilevazione  REAL    NOT NULL,
    velocita_rilevata INTEGER NOT NULL,
    velocita_massima  INTEGER NOT NULL,

    importo         REAL    NOT NULL,
    timestamp       TEXT    NOT NULL,

    stato           INTEGER DEFAULT 1
);

CREATE INDEX IF NOT EXISTS idx_infrazioni_velocita_targa ON infrazioni_velocita(targa);
CREATE INDEX IF NOT EXISTS idx_infrazioni_velocita_biglietto ON infrazioni_velocita(id_biglietto);</sql><current_tab id="0"/></tab_sql></sqlb_project>
